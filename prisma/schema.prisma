datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         String   @default("USER")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions           Session[]
  passwordResets     PasswordReset[]
  encounters         Encounter[]
  ledger             LedgerEntry[]
  purchases          Purchase[]
  scenes             Scene[]
  characters         Character[]
  favoriteScenes     FavoriteScene[]
  favoriteCharacters FavoriteCharacter[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Scene {
  id                  String   @id @default(cuid())
  authorId            String

  // Section A — Environment
  title               String
  setting             String
  subLocation         String   @default("")
  timeOfDay           String   @default("Evening")
  lighting            String   @default("Warm ambient")
  atmosphere          String   @default("Intimate")
  environmentDetails  String?

  // Section B — Situation
  coreSituation       String
  relationshipDynamic String   @default("Strangers")
  leadIntent          String   @default("Curious about the user")
  openingMoment       String
  emotionalTone       String   @default("Controlled tension")
  emotionalHook       String
  encounterGoal       String   @default("Build quiet tension")

  // Generated content
  generatedPrompt     String?
  imagePrompt         String?
  teaserText          String?
  coverImage          String?

  // Admin / system
  toneTags            String   @default("[]")
  status              String   @default("DRAFT")
  tier                String   @default("COMMUNITY")
  clickCount          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  author      User            @relation(fields: [authorId], references: [id])
  encounters  Encounter[]
  favoritedBy FavoriteScene[]
}

model Character {
  id                    String   @id @default(cuid())
  authorId              String

  // Section A — Visual Identity
  name                  String
  visualSex             String   @default("Unspecified")
  genderExpression      String   @default("Unspecified")
  raceEthnicity         String?
  apparentAge           String   @default("30s")
  build                 String   @default("Athletic")
  presence              String   @default("Controlled")
  hairStyle             String   @default("Short")
  hairColor             String   @default("Brown")
  eyeColor              String   @default("Brown")
  distinguishingFeature String?

  // Section B — Personality
  setting               String   @default("MODERN")
  primaryType           String
  secondaryTrait        String?
  corePersonality       String
  interactionStyle      String
  dialogueTone          String
  emotionalStartingState String  @default("Calm and assessing")
  alwaysBehaviors       String   @default("[]")
  neverBehaviors        String   @default("[]")

  // Generated content
  generatedPrompt       String?
  imagePrompt           String?
  teaserText            String?
  portraitImage         String?

  // Admin / system
  status                String   @default("DRAFT")
  tier                  String   @default("COMMUNITY")
  selectionCount        Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  author      User                @relation(fields: [authorId], references: [id])
  encounters  Encounter[]
  favoritedBy FavoriteCharacter[]
}

model FavoriteScene {
  userId    String
  sceneId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@id([userId, sceneId])
}

model FavoriteCharacter {
  userId      String
  characterId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([userId, characterId])
}

model Encounter {
  id             String   @id @default(cuid())
  userId         String
  sceneId        String
  characterId    String
  status         String   @default("ACTIVE")
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id          String   @id @default(cuid())
  encounterId String
  role        String
  content     String
  heartCost   Float    @default(0)
  createdAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model LedgerEntry {
  id           String   @id @default(cuid())
  userId       String
  type         String
  amount       Decimal
  balanceAfter Decimal
  referenceId  String?
  note         String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Purchase {
  id              String    @id @default(cuid())
  userId          String
  heartsAmount    Int
  amountUsdCents  Int
  stripePaymentId String    @unique
  status          String    @default("PENDING")
  refundId        String?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model EngagementEvent {
  id          String   @id @default(cuid())
  userId      String?
  eventType   String
  sceneId     String?
  characterId String?
  encounterId String?
  createdAt   DateTime @default(now())
}
